{
  "version": 2,
  "builds": [
    {
      "src": "run.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/api/(.*)",    "dest": "/run.py" },
    { "src": "/(.*)",        "dest": "/run.py" }
  ],
  "env": {
    "FLASK_ENV":   "production",
    "FLASK_DEBUG": "false",
    "LOG_FORMAT":  "json",
    "LOG_LEVEL":   "INFO"
  }
}
